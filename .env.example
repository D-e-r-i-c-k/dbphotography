# Sanity (required)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: for server-side or private content
SANITY_API_READ_TOKEN=
# Server-side write token for automation (keep secret)
SANITY_API_WRITE_TOKEN=

# PayFast – South Africa payments (required for photo sales)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
# Optional: if you set a passphrase in PayFast dashboard
PAYFAST_PASSPHRASE=

# Formspree – contact form
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Cloudinary – optional; for image transforms and watermarking
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App URL – for webhooks and redirects (e.g. https://yoursite.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: a secret string to protect the sync endpoint. If set, requests must include header 'x-sync-secret'
SYNC_SECRET=
